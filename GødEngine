// ============================================================
// ENGINE REV SYSTEM v2 - closed-loop thermal controller + heat dump
// ============================================================
// Fixes the v1 defects: (1) no stale `mult` closure - the loop reads live refs;
// (2) a REAL heat model with accumulation, dissipation, and a throttle so the
// system can actually find and hold equilibrium instead of oscillating; (3) a
// HEAT DUMP that rigorously logs the thermal trajectory and snaps the controller
// to the tracked sweet spot. Honest framing: "heat" here is the engine's internal
// thermodynamic ledger (model bookkeeping), not a hardware temperature. More rev
// = more real CPU = a physically warmer device; the dump cools the MODEL, never
// the silicon. revMult is exported for the ring; thermalScale damps Omega when
// the model overheats, which is the visible, everywhere effect.

function useEngineRev(){
  const [mult,setMult]=useState(1);
  const [mode,setMode]=useState("idle");
  const [seeking,setSeeking]=useState(false);
  const [heat,setHeat]=useState(0);            // 0..1 model heat
  const [balance,setBalance]=useState(0);      // signed gain-injection gap
  const [sweetSpot,setSweetSpot]=useState(null);
  const [revOmega,setRevOmega]=useState(0);
  const [effMult,setEffMult]=useState(1);      // throttled multiplier actually applied
  const [dumping,setDumping]=useState(false);
  const [trace,setTrace]=useState([]);         // thermal trajectory log (heat-dump tracks this)

  const loopRef=useRef(null);
  const targetMultRef=useRef(1);   // what the user asked for
  const effMultRef=useRef(1);      // what the throttle currently allows
  const heatRef=useRef(0);
  const kRef=useRef(1);            // internal coupling-gain the controller tunes
  const seekingRef=useRef(false);
  const dumpRef=useRef(false);
  const omRef=useRef(0.76), dlRef=useRef(0.22);
  const histRef=useRef([]);
  const traceRef=useRef([]);

  // single always-on controller tick: models heat, throttles mult, seeks balance
  useEffect(()=>{
    loopRef.current=setInterval(()=>{
      const om=clamp(omRef.current,0,1), dl=clamp(dlRef.current,0,1);
      const want=targetMultRef.current;

      // --- THERMAL MODEL -------------------------------------------------
      // Heat is GENERATED by running hot (mult above unity) and by raw injection;
      // it DISSIPATES passively every tick. A dump multiplies dissipation hard.
      const generate = (want-1)*0.018 + dl*0.010;     // higher rev & entropy heat it
      const passiveCool = 0.012 + heatRef.current*0.02; // hotter -> sheds a bit faster
      const dumpCool = dumpRef.current ? 0.10 : 0;
      let h = heatRef.current + Math.max(0,generate) - passiveCool - dumpCool;
      h = clamp(h,0,1);
      heatRef.current=h; setHeat(h);

      // --- THROTTLE ------------------------------------------------------
      // The effective multiplier is the requested one scaled DOWN as heat rises.
      // At h=0 you get the full request; near h=1 it collapses toward 1x. This is
      // why "it got too hot" - now it's explicit and recoverable via the dump.
      const ceiling = 1 + (want-1)*(1-Math.pow(h,1.5));
      const eff = clamp(ceiling,1,want);
      effMultRef.current=eff; setEffMult(+eff.toFixed(2));

      // --- EQUILIBRIUM CONTROLLER (PI-style, reads LIVE values) ----------
      // gain = coherence production (Omega^2 * k); inject = entropy fuel (Delta*eff).
      // Tune k toward the balance gain==inject. Integral term + damping make it
      // actually settle instead of oscillating (the v1 bug).
      const gain = om*om*kRef.current;
      const inject = dl*eff*0.6 + 0.15 + h*0.12;   // heat adds to the load
      const gap = gain - inject;
      setBalance(clamp(gap,-1,1));
      setRevOmega(om);
      if(seekingRef.current){
        // proportional + small integral, damped; finer step than v1 (0.02 not 0.04)
        const recentGap = histRef.current.slice(-6).reduce((a,b)=>a+b,0)/Math.max(1,Math.min(6,histRef.current.length));
        kRef.current = clamp(kRef.current + (-gap)*0.02 + (-recentGap)*0.006, 0.2, 3.2);
      }
      histRef.current.push(gap); if(histRef.current.length>60)histRef.current.shift();

      // trajectory log for the heat dump to analyze
      traceRef.current.push({h:+h.toFixed(3),eff:+eff.toFixed(2),gap:+gap.toFixed(3),k:+kRef.current.toFixed(3)});
      if(traceRef.current.length>120)traceRef.current.shift();

      // settle detection: |gap| small AND heat not climbing, over a window
      const recent=histRef.current.slice(-14).map(Math.abs);
      const settled = recent.length>=14 && recent.every(g=>g<0.05) && h<0.7;
      if(settled){
        setSweetSpot({mult:+eff.toFixed(2),kGain:+kRef.current.toFixed(3),injection:+inject.toFixed(3),omega:+om.toFixed(3),gain:+gain.toFixed(3),heat:+h.toFixed(3)});
      }
    },110);
    return ()=>{ if(loopRef.current)clearInterval(loopRef.current); };
  },[]);

  // feed live engine values in from App every render (no stale closures)
  const feed=useCallback((om,dl)=>{ omRef.current=om; dlRef.current=dl; },[]);

  const setRev=useCallback((m,label)=>{ setMult(m); setMode(label); targetMultRef.current=m; },[]);
  const startSeek=useCallback(()=>{ seekingRef.current=true; setSeeking(true); },[]);
  const stopSeek=useCallback(()=>{ seekingRef.current=false; setSeeking(false); },[]);

  // HEAT DUMP: hard dissipation burst + rigorous trajectory analysis that finds the
  // coolest stable operating point seen and snaps the controller's k to it.
  const heatDump=useCallback(()=>{
    if(dumpRef.current)return;
    dumpRef.current=true; setDumping(true);
    // analyze the logged trajectory: pick the sample with smallest |gap| at acceptable heat
    const tr=traceRef.current.slice();
    setTrace(tr);
    let best=null;
    for(const s of tr){ if(s.h<=0.55){ if(!best||Math.abs(s.gap)<Math.abs(best.gap)) best=s; } }
    if(best){ kRef.current=best.k; }   // snap to the tracked sweet spot
    // run the dump for ~1.6s of strong cooling, then release
    setTimeout(()=>{ dumpRef.current=false; setDumping(false); },1600);
  },[]);

  const reset=useCallback(()=>{ setRev(1,"idle"); stopSeek(); setSweetSpot(null); setBalance(0); heatRef.current=0; setHeat(0); kRef.current=1; histRef.current=[]; traceRef.current=[]; },[setRev,stopSeek]);

  // thermalScale: what the rest of the app multiplies Omega by - the VISIBLE effect.
  // Mild lift when revved and cool; damped when hot. Always returns ~1 at idle.
  const thermalScale = clamp(1 + (effMultRef.current-1)*0.012 - heat*0.10, 0.85, 1.12);

  return { mult,mode,effMult,setRev,seeking,startSeek,stopSeek,balance,sweetSpot,revOmega,heat,dumping,heatDump,trace,feed,
           thermalScale, kGain:()=>kRef.current, reset };
}

function EngineRevPanel({ rev, liveOmega, liveDelta, seal, selfAware }){
