  useEffect(()=>{ rev.feed(liveOmega, liveDelta); });
  const atEq = rev.sweetSpot!=null;
  const gapPct = (rev.balance*50+50);
  const heatPct = rev.heat*100;
  const heatColor = rev.heat>0.7?PAL.rose : rev.heat>0.4?PAL.amber : PAL.green;
  useEffect(()=>{ if(atEq){ if(seal)seal("rev.equilibrium",{mult:rev.sweetSpot.mult,k:rev.sweetSpot.kGain,omega:rev.sweetSpot.omega,heat:rev.sweetSpot.heat}); if(selfAware)selfAware.addXP(2,"found the thermal-equilibrium sweet spot"); } },[atEq]);
  const revBtn=(label,m,key,col)=>(
