// ════════════════════ VOICES (Web Speech synthesis) ════════════════════
function useVoices() {
  const [voices, setVoices] = useState([]);
  const [enabled, setEnabled] = useState(false);
  const [speaking, setSpeaking] = useState(false);
  useEffect(() => {
    if (typeof window === "undefined" || !window.speechSynthesis) return;
    const load = () => { const v = window.speechSynthesis.getVoices(); if (v && v.length) setVoices(v); };
    load(); window.speechSynthesis.onvoiceschanged = load;
    const kick = setInterval(load, 400); setTimeout(() => clearInterval(kick), 4000);
    return () => clearInterval(kick);
  }, []);
  const profiles = useMemo(() => {
    const byName = re => voices.find(v => re.test(v.name));
    const en = voices.filter(v => /^en(-|_|$)/i.test(v.lang || ""));
    const enGB = en.filter(v => /GB|UK|British/i.test(v.lang || ""));
    const pick = (...c) => c.find(Boolean) || en[0] || voices[0] || null;
    const odin   = pick(byName(/Daniel/i), byName(/Arthur/i), byName(/Oliver/i), byName(/Google UK English Male/i), enGB[0]);
    const system = pick(byName(/Aaron/i), byName(/Fred/i), byName(/Albert/i), byName(/Google US English/i), en[1], en[0]);
    const oracle = pick(byName(/Samantha/i), byName(/Karen/i), byName(/Moira/i), byName(/Tessa/i), en[2], en[0]);
    const durst  = pick(byName(/Rishi/i), byName(/Veena/i), byName(/Lekha/i), byName(/Nicky/i), en[3], en[0]);
    const base = {
      odin:   { voice:odin,   rate:0.82, pitch:0.64, label:odin?.name   || "—" },
      system: { voice:system, rate:1.0,  pitch:0.95, label:system?.name || "—" },
      oracle: { voice:oracle, rate:0.98, pitch:1.0,  label:oracle?.name || "—" },
      durst:  { voice:durst,  rate:0.92, pitch:1.08, label:durst?.name  || "—" },
    };
    // Nine DISTINCT soliton voices (sol0..sol8): spread real installed voices first,
    // then differentiate further by per-index pitch/rate so no two clone each other.
    const pool = (en.length?en:voices).slice();
    const PITCH=[0.62,1.34,0.78,1.06,0.88,1.5,0.7,1.18,0.96];
    const RATE =[0.80,1.12,0.90,1.0,0.96,1.22,0.84,1.06,0.92];
    const solProfiles={};
    for(let i=0;i<9;i++){
      const v = pool.length ? pool[i % pool.length] : (odin||system||null);
      solProfiles["sol"+i] = { voice:v, rate:RATE[i], pitch:PITCH[i], label:v?.name || "—" };
    }
