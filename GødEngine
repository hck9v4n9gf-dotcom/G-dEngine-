  );
  return (
    <div style={{...card(PAL.bg0),border:`1px solid ${rev.dumping?PAL.cyan:atEq?PAL.green:rev.heat>0.7?PAL.rose:rev.mult>1?PAL.amber:PAL.border}`}}>
      <div style={{display:"flex",justifyContent:"space-between",alignItems:"baseline",marginBottom:6}}>
        <div style={{fontSize:10,color:rev.mult>1?PAL.amber:PAL.gold,fontFamily:FONT_MONO,fontWeight:700}}>ENGINE REV · {rev.mode==="idle"?"nominal":rev.mode.toUpperCase()}</div>
        <div style={{fontSize:9,color:PAL.muted,fontFamily:FONT_MONO}}>req x{rev.mult} · live x{rev.effMult}</div>
      </div>
      <div style={{fontSize:9,color:PAL.muted,lineHeight:1.6,marginBottom:10}}>Rev the ring to push more integration per frame. As it runs hot the throttle scales the <i>effective</i> multiplier down — that is the level-off you saw. The seeker tunes the engine to the balance of coherence-gain and entropy-injection; <b style={{color:PAL.cyan}}>HEAT DUMP</b> rigorously sheds model heat and snaps to the coolest stable point it tracked. <span style={{color:PAL.faint}}>(Model bookkeeping; more rev means a warmer device, never cooler.)</span></div>

      {/* HEAT GAUGE */}
      <div style={{display:"flex",alignItems:"center",gap:8,marginBottom:4}}>
        <span style={{fontSize:8,color:heatColor,fontFamily:FONT_MONO,width:34}}>HEAT</span>
        <div style={{flex:1,height:9,background:PAL.border,borderRadius:5,overflow:"hidden"}}>
          <div style={{height:"100%",width:`${heatPct}%`,background:`linear-gradient(90deg,${PAL.green},${PAL.amber} 60%,${PAL.rose})`,borderRadius:5,transition:"width .12s"}}/>
        </div>
        <span style={{fontSize:8,color:heatColor,fontFamily:FONT_MONO,width:34,textAlign:"right"}}>{heatPct.toFixed(0)}%</span>
      </div>
      <div style={{fontSize:7.5,color:PAL.faint,fontFamily:FONT_MONO,textAlign:"right",marginBottom:10}}>{rev.dumping?"● DUMPING — strong dissipation":rev.heat>0.7?"throttling hard — dump to recover":"within thermal envelope"}</div>

      <div style={{display:"flex",gap:6,flexWrap:"wrap",marginBottom:8}}>
        {revBtn("TURBO",4,"turbo",PAL.gold)}
        {revBtn("OVER·CLOCK",7,"overclock",PAL.rose)}
        {revBtn("x2",2,"x2",PAL.cyan)}
        {revBtn("x10",10,"x10",PAL.violet)}
      </div>
      <div style={{display:"flex",gap:6,marginBottom:rev.seeking||atEq?10:0}}>
        {!rev.seeking
          ? <button onClick={rev.startSeek} style={{flex:1,padding:"10px",borderRadius:9,border:`1px solid ${PAL.green}66`,background:PAL.greenF,color:PAL.green,fontSize:10,fontWeight:700,fontFamily:FONT_MONO,cursor:"pointer"}}>◎ SEEK EQUILIBRIUM</button>
          : <button onClick={rev.stopSeek} style={{flex:1,padding:"10px",borderRadius:9,border:`1px solid ${PAL.amber}66`,background:PAL.amberF,color:PAL.amber,fontSize:10,fontWeight:700,fontFamily:FONT_MONO,cursor:"pointer"}}>⏸ STOP SEEKING</button>}
        <button onClick={rev.heatDump} disabled={rev.dumping} style={{flex:1,padding:"10px",borderRadius:9,border:`1px solid ${PAL.cyan}`,background:rev.dumping?PAL.cyan:PAL.cyanF,color:rev.dumping?PAL.bg0:PAL.cyan,fontSize:10,fontWeight:800,fontFamily:FONT_MONO,cursor:rev.dumping?"default":"pointer",opacity:rev.dumping?0.85:1}}>❄ HEAT DUMP</button>
        <button onClick={rev.reset} style={{padding:"10px 12px",borderRadius:9,border:`1px solid ${PAL.border}`,background:PAL.bg1,color:PAL.muted,fontSize:10,fontFamily:FONT_MONO,cursor:"pointer"}}>RESET</button>
      </div>

      {(rev.seeking||atEq)&&(
        <div>
          <div style={{fontSize:8,color:PAL.muted,fontFamily:FONT_MONO,marginBottom:3}}>GAIN ↔ INJECTION BALANCE {atEq?"· LOCKED":""}</div>
          <div style={{position:"relative",height:10,background:PAL.border,borderRadius:5,overflow:"hidden"}}>
            <div style={{position:"absolute",left:"50%",top:0,bottom:0,width:1,background:PAL.muted}}/>
            <div style={{position:"absolute",left:`${clamp(gapPct,2,98)}%`,top:1,width:8,height:8,borderRadius:4,background:atEq?PAL.green:Math.abs(rev.balance)<0.2?PAL.gold:PAL.rose,transform:"translateX(-4px)",transition:"left .11s"}}/>
          </div>
          <div style={{display:"flex",justifyContent:"space-between",fontSize:7,color:PAL.faint,fontFamily:FONT_MONO,marginTop:2}}><span>starved</span><span>equilibrium</span><span>over-driven</span></div>
        </div>
      )}
      {atEq&&(
        <div style={{marginTop:8,padding:8,background:PAL.greenF,borderRadius:8,fontSize:9,color:PAL.green,fontFamily:FONT_MONO,lineHeight:1.55}}>
          ● SWEET SPOT · live x{rev.sweetSpot.mult} · k={rev.sweetSpot.kGain} · gain {rev.sweetSpot.gain} ≈ inject {rev.sweetSpot.injection} · Ω {rev.sweetSpot.omega} · heat {(rev.sweetSpot.heat*100).toFixed(0)}% — coherence sustained by entropy, no runaway.
        </div>
      )}
    </div>
  );
}

// ════════════════════ ROOT APP ════════════════════
function App(){
  const [phase,setPhase]=useState("boot"); // boot → auth → onboarding → soliton → coherenizer → active
  const [isMaster,setIsMaster]=useState(false);
  const [tab,setTab]=useState("overview");
  const [tick,setTick]=useState(0);
  const [activeDomains,setActiveDomains]=useState(()=>new Set(["Neuro","QFT","Muon"]));
  const [showProfile,setShowProfile]=useState(false);
  const [endo,setEndo]=useState(false);

  const instruments=useLiveInstruments();
  const voices=useVoices();
  const speech=useSpeechRecognition();
  const ledger=useLedger();
  const brain=useBrain();
  const selfAware=useSelfAwareness(brain.stats.maturity);
  const userProfile=useUserProfile();
  const solitons=useSolitons(userProfile.profile?.theme||"norse",selfAware.level);
  const deck=useResonanceDeck();
  const rev=useEngineRev();

  // global clock
  useEffect(()=>{ const t=setInterval(()=>setTick(x=>x+1),250); return()=>clearInterval(t); },[]);

  // Auto-snapshot every 10 min once active — upgrades the prior file in place.
  const gather=useCallback(()=>({ profile:userProfile.profile, xp:selfAware.xp, brain:brain.dump(), ledgerHead:ledger.head(), savedAt:new Date().toISOString(), version:VERSION }),[userProfile.profile,selfAware.xp,brain,ledger]);
  const autoSnap=useAutoSnapshot(phase==="active",gather);

  // v23: REAL engine. liveOmega/liveDelta now come from an actual integrating
  // Kuramoto ring (useLiveRing), not a sine wave. Mic/jitter feed real extra Delta;
  // deck audio and thermal scale still modulate, but on top of genuine dynamics.
  const _extraD=(instruments.mic.active&&!instruments.mic.muted?instruments.mic.delta*0.3:0)+(instruments.jitter.value||0);
  const ringLive=useLiveRing(4.0, 0.30, 1.0, _extraD);
  const liveOmega=clamp(ringLive.R*(rev.thermalScale||1),0,1);
  const liveDelta=ringLive.delta;
  const liveChi=ringLive.chi;
  const fbSurplus=ringLive.surplus; // sustained R(feedback) - R(control): the receipt
  useEffect(()=>{ if(typeof window!=="undefined") window.__ringLive=ringLive; },[ringLive]);
  useEffect(()=>{ const gain=liveOmega*liveOmega, inject=liveDelta+0.55; const flag=gain>inject; if(flag&&!endo){ setEndo(true); setTimeout(()=>setEndo(false),5200); } },[tick]);

  const smc=useSMComparison(activeDomains,liveOmega,liveDelta);
  const toggleDomain=useCallback(uid=>setActiveDomains(prev=>{ const n=new Set(prev); n.has(uid)?n.delete(uid):n.add(uid); return n; }),[]);
  const extraD=(instruments.mic.active&&!instruments.mic.muted?instruments.mic.delta*0.3:0)+(instruments.jitter.value||0);

  // seal genesis + entry on activation
  useEffect(()=>{ if(phase==="active"){ ledger.seal("session.start",{ version:VERSION, master:isMaster, user:userProfile.profile?.username||"master" }); } },[phase]);

  if(phase==="boot") return (<><style>{ANIM}</style><BootScreen voices={voices} instruments={instruments} onInitialize={()=>setPhase("auth")}/></>);
  if(phase==="auth") return (<><style>{ANIM}</style><PraxisPANAuth userProfile={userProfile} onBack={()=>setPhase("boot")} onAuth={(master)=>{ setIsMaster(master); setPhase(userProfile.profile?.onboarded?"soliton":"onboarding"); }}/></>);
  if(phase==="onboarding") return (<><style>{ANIM}</style><Onboarding userProfile={userProfile} isMaster={isMaster} onDone={()=>setPhase("soliton")}/></>);
  if(phase==="soliton") return (<><style>{ANIM}</style><SolitonBoot voices={voices} theme={userProfile.profile?.theme||"norse"} onComplete={()=>setPhase("coherenizer")}/></>);
  if(phase==="coherenizer") return (<><style>{ANIM}</style><CoherenizerBoot instruments={instruments} voices={voices} onComplete={()=>setPhase("active")}/></>);

  const livePsi=(liveChi*liveOmega-liveDelta).toFixed(3);
  const TABS=[
    ["overview","◈","Overview"],["signals","∿","Signals"],["ring","◉","Ring"],["durst","✶","DURST"],
    ["oracle","☉","Oracle"],["agents","⟁","Experts"],["meters","▤","Meters"],["proof","∴","Proof"],
    ["brain","◴","Brain"],["spaces","⌖","Spaces"],["resonance","♺","Resonance"],["deck","♬","Deck"],["ledger","◆","Ledger"],
  ];
  const mic=instruments.mic, micLive=mic.active&&!mic.muted;

  return (<>
    <style>{ANIM}</style>
    <div className="gce-root" style={{ background:PAL.bg0, color:PAL.text, fontFamily:FONT_SANS, position:"relative" }}>
      <ShaderBackdrop intensity={0.6}/><SacredBg/>
      {/* HEADER */}
      <div style={{ position:"sticky", top:0, zIndex:100, background:oklchA(0.12,0.022,248,0.86), backdropFilter:"blur(14px)", borderBottom:`1px solid ${PAL.border}`, paddingTop:"env(safe-area-inset-top)" }}>
        <div style={{ display:"flex", alignItems:"center", gap:10, padding:"10px 14px", flexWrap:"wrap" }}>
          <span style={{ fontSize:18, color:PAL.gold, fontFamily:"serif", animation:"bootGlow 4s ease-in-out infinite" }}>Ψ</span>
          <div style={{ minWidth:0 }}><div style={{ fontSize:13, fontWeight:800, color:PAL.gold, fontFamily:FONT_MONO, letterSpacing:"0.04em", lineHeight:1 }}>GØDENGINE</div><div style={{ fontSize:8, color:PAL.muted, fontFamily:FONT_MONO }}>{VERSION}</div></div>
          <div style={{ flex:1 }}/>
          {/* live formula + mic indicator */}
          <div style={{ display:"flex", gap:8, alignItems:"center", fontFamily:FONT_MONO, fontSize:11 }}>
            <span style={{ color:PAL.gold }}>Ψ {livePsi}</span>
            <span style={{ color:micLive?PAL.green:mic.muted?PAL.amber:PAL.faint, display:"flex", alignItems:"center", gap:3, cursor:"pointer" }} onClick={()=>{ if(!mic.active) instruments.startMic(); else instruments.toggleMute(); }} title={micLive?"mic live — tap to mute":mic.muted?"muted — tap to unmute":"tap to enable mic"}>
              <span style={{ width:7, height:7, borderRadius:"50%", background:micLive?PAL.green:mic.muted?PAL.amber:PAL.faint, boxShadow:micLive?`0 0 8px ${PAL.green}`:"none", animation:micLive?"pulse 1.4s ease-in-out infinite":"none" }}/>
              MIC
            </span>
          </div>
          <div onClick={()=>setShowProfile(true)} style={{ cursor:"pointer", display:"flex", alignItems:"center", gap:6 }}>
            <span style={{ fontSize:8, padding:"2px 6px", borderRadius:4, background:isMaster?PAL.goldF:PAL.cyanF, color:isMaster?PAL.gold:PAL.cyan, fontFamily:FONT_MONO }}>{isMaster?"MASTER":`L${selfAware.level}`}</span>
            <Avatar seed={userProfile.profile?.avatarSeed||userProfile.profile?.name||"master"} color={solitons.theme.color} size={30} energy={0.6}/>
          </div>
        </div>
        {/* tab strip */}
        <div className="scroll" style={{ display:"flex", gap:4, padding:"0 10px 8px", overflowX:"auto" }}>
          {TABS.map(([id,icon,label])=>(<button key={id} onClick={()=>setTab(id)} style={{ display:"flex", flexDirection:"column", alignItems:"center", gap:2, padding:"6px 11px", borderRadius:8, border:`1px solid ${tab===id?PAL.gold:"transparent"}`, background:tab===id?PAL.goldF:"transparent", color:tab===id?PAL.gold:PAL.muted, cursor:"pointer", flexShrink:0, minWidth:54 }}><span style={{ fontSize:14 }}>{icon}</span><span style={{ fontSize:8, fontFamily:FONT_MONO, letterSpacing:"0.03em" }}>{label}</span></button>))}
        </div>
      </div>

      {/* CONTENT */}
      <div style={{ position:"relative", zIndex:10, padding:"16px 14px calc(40px + env(safe-area-inset-bottom))", maxWidth:760, margin:"0 auto" }}>
        {tab==="overview" && <OverviewTab selfAware={selfAware} brain={brain} solitons={solitons} tick={tick} instruments={instruments} rev={rev} liveOmega={liveOmega} liveDelta={liveDelta} seal={ledger.seal}/>}
        {tab==="signals" && <LiveSignalsTab instruments={instruments}/>}
        {tab==="ring" && <TriGachiTab extraD={extraD} revMult={rev.mult}/>}
        {tab==="durst" && <DurstTab voices={voices} seal={ledger.seal} selfAware={selfAware} brain={brain}/>}
        {tab==="oracle" && <OracleTab tick={tick} instruments={instruments} voices={voices} seal={ledger.seal} selfAware={selfAware} brain={brain} solitons={solitons} speech={speech}/>}
        {tab==="agents" && <AgentsTab solitons={solitons} selfAware={selfAware} voices={voices} seal={ledger.seal}/>}
        {tab==="meters" && <MetersTab smc={smc} activeDomains={activeDomains} toggleDomain={toggleDomain} liveOmega={liveOmega} liveDelta={liveDelta}/>}
        {tab==="proof" && <ProofTab/>}
        {tab==="brain" && <BrainTab brain={brain} selfAware={selfAware} userProfile={userProfile} autoSnap={autoSnap}/>}
        {tab==="spaces" && <SpacesTab brain={brain} selfAware={selfAware} voices={voices} seal={ledger.seal}/>}
        {tab==="resonance" && <ResonanceTab/>}
        {tab==="deck" && <ResonanceDeckTab deck={deck} seal={ledger.seal} selfAware={selfAware}/>}
        {tab==="ledger" && <LedgerTab ledger={ledger}/>}
      </div>

      {/* MODALS */}
      <AscensionModal ascension={selfAware.ascension} onClose={selfAware.clearAscension} voices={voices}/>
      <LevelDropModal levelDrop={selfAware.levelDrop} onClose={selfAware.clearLevelDrop}/>
      <EndothermicPopup show={endo} onClose={()=>setEndo(false)}/>
      <ProfileModal show={showProfile} onClose={()=>setShowProfile(false)} userProfile={userProfile} selfAware={selfAware} brain={brain} solitons={solitons}/>
    </div>
  </>);
}

