    if (typeof window === "undefined" || !window.speechSynthesis) return;
    try { const u = new SpeechSynthesisUtterance(" "); u.volume = 0; window.speechSynthesis.speak(u); } catch (_) {}
  }, []);
  const speak = useCallback((persona, text, { interrupt = true } = {}) => {
    if (!enabled || typeof window === "undefined" || !window.speechSynthesis || !text) return;
    const p = profiles[persona] || profiles.system;
    try {
      if (interrupt) window.speechSynthesis.cancel();
      const u = new SpeechSynthesisUtterance(String(text).slice(0, 600));
      if (p.voice) u.voice = p.voice;
      u.rate = p.rate; u.pitch = p.pitch; u.volume = 1;
