    let score=0;
    s.domains.forEach(uid=>{ const d=DOMAINS.find(x=>x.uid===uid); if(!d) return;
      if(q.includes(uid.toLowerCase())) score+=5;
      d.name.toLowerCase().split(/[^a-z]+/).forEach(w=>{ if(w.length>3&&q.includes(w)) score+=3; });
      d.expertise.toLowerCase().split(/[^a-z]+/).forEach(w=>{ if(w.length>4&&q.includes(w)) score+=2; });
