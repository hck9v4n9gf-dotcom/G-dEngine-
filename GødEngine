// ════════════════════ AUTO-SNAPSHOT (every 10 minutes) ════════════════════
// Systematically saves a full snapshot to the device and upgrades the prior file in place.
function useAutoSnapshot(active, gatherFn){
  const [lastSnap,setLastSnap]=useState(()=>LS.get("gce_snap_meta",null));
  const timerRef=useRef(null);
  const snapshot=useCallback((reason="auto")=>{
    try{
      const payload=gatherFn();
      const meta={ ts:new Date().toISOString(), reason, version:VERSION, size:JSON.stringify(payload).length };
      LS.set("gce_snapshot", payload);          // upgrades (overwrites) the prior snapshot file
      LS.set("gce_snap_meta", meta);
      setLastSnap(meta);
      return meta;
    }catch(e){ return null; }
  },[gatherFn]);
  useEffect(()=>{
    if(!active) return;
    timerRef.current=setInterval(()=>snapshot("auto-10min"), 600000); // 10 minutes
    const onHide=()=>{ if(document.visibilityState==="hidden") snapshot("visibility"); };
    document.addEventListener("visibilitychange",onHide);
    window.addEventListener("beforeunload",()=>snapshot("unload"));
    return ()=>{ if(timerRef.current) clearInterval(timerRef.current); document.removeEventListener("visibilitychange",onHide); };
  },[active,snapshot]);
  return { lastSnap, snapshot };
}
