// ============================================================
// RESONANCE DECK - live Web Audio synthesis, Kuramoto-coupled layers
// ============================================================
// No external audio files. Each layer is a synthesized voice (oscillator or
// filtered noise) AND a Kuramoto oscillator with its own phase/natural freq.
// The user is a DJ: nudge coupling K, detune layers, trigger drops/interrupts,
// inject perturbations. The layers' order parameter Omega_audio feeds back into
// the Psi witness, so tighter musical lock visibly raises coherence.
// All on-device, zero licensing exposure. Optional local-file path is separate.

function useResonanceDeck(){
  const [active,setActive]=useState(false);
  const [layers,setLayers]=useState([]);     // UI mirror of layer state
  const [coupling,setCoupling]=useState(0.6);
  const [omegaAudio,setOmegaAudio]=useState(0);
  const [master,setMaster]=useState(0.5);
  const [bpm,setBpm]=useState(96);
  const [drop,setDrop]=useState(false);
  const nodesRef=useRef(null);                // live audio graph (not state)
  const phaseRef=useRef(null);                // kuramoto phases/natural freqs
  const rafRef=useRef(null);
  const masterGainRef=useRef(null);
  const couplingRef=useRef(0.6);
  const dropRef=useRef(false);
  const stepRef=useRef(0);

  // 6 musical layers: kick, bass, pad-A, pad-B, pluck, shimmer.
  // Each has a base frequency (Hz) and a role. Phase governs its rhythmic gate.
  const LAYER_DEFS=useMemo(()=>[
    {id:"sub",    label:"Sub Drone", type:"sine",     base:55.00, role:"low",     color:PAL.gold,   natFreq:0.060, gate:"drone"},
    {id:"root",   label:"Root",      type:"triangle", base:110.00,role:"low",     color:PAL.amber,  natFreq:0.090, gate:"drone"},
    {id:"fifth",  label:"Fifth",     type:"triangle", base:164.81,role:"harmony", color:PAL.cyan,   natFreq:0.110, gate:"drone"},
    {id:"octave", label:"Octave",    type:"sine",     base:220.00,role:"harmony", color:PAL.ice,    natFreq:0.130, gate:"drone"},
    {id:"third",  label:"Third",     type:"sine",     base:329.63,role:"air",     color:PAL.violet, natFreq:0.155, gate:"drone"},
    {id:"air",    label:"Air",       type:"sine",     base:493.88,role:"air",     color:PAL.magenta,natFreq:0.180, gate:"drone"},
  ],[]);

  const buildGraph=useCallback((ctx)=>{
    const master=ctx.createGain();
    master.gain.value=0.0; // ramp up after start
    // soft limiter so layered synths never clip harshly
    const comp=ctx.createDynamicsCompressor();
    comp.threshold.value=-18; comp.knee.value=20; comp.ratio.value=4; comp.attack.value=0.003; comp.release.value=0.25;
    master.connect(comp); comp.connect(ctx.destination);
    masterGainRef.current=master;
    const nodes=LAYER_DEFS.map(def=>{
      const osc=ctx.createOscillator(); osc.type=def.type; osc.frequency.value=def.base;
      const g=ctx.createGain(); g.gain.value=0;
      // gentle per-voice lowpass to tame the saw/square edges
      const lp=ctx.createBiquadFilter(); lp.type="lowpass"; lp.frequency.value=def.role==="sparkle"?5200:def.role==="harmony"?2600:1400; lp.Q.value=0.6;
      osc.connect(lp); lp.connect(g); g.connect(master);
      osc.start();
      return {def,osc,g,lp,muted:false,detune:0,level:def.role==="pulse"?0.9:def.role==="low"?0.7:0.4};
    });
    nodesRef.current=nodes;
    return master;
  },[LAYER_DEFS]);

  const start=useCallback(async()=>{
    if(active)return;
    const ctx=getAudioCtx();
    if(!ctx){return;}
    try{ if(ctx.state==="suspended") await ctx.resume(); }catch(e){}
    if(!nodesRef.current) buildGraph(ctx);
    // init kuramoto phases
    phaseRef.current=LAYER_DEFS.map((d,i)=>({phase:Math.random()*TAU,nat:d.natFreq}));
    // ramp master up
    const now=ctx.currentTime;
    masterGainRef.current.gain.cancelScheduledValues(now);
    masterGainRef.current.gain.setValueAtTime(masterGainRef.current.gain.value,now);
    masterGainRef.current.gain.linearRampToValueAtTime(master,now+0.6);
    setActive(true);
    // animation loop drives kuramoto coupling + rhythmic gating
    let last=performance.now();
    const loop=(t)=>{
      const ctx2=getAudioCtx(); if(!ctx2){return;}
      const dt=Math.min(0.05,(t-last)/1000); last=t;
      const ph=phaseRef.current; const K=couplingRef.current;
      const beatHz=bpmRef.current/60;
      // mean field
      let sx=0,sy=0; for(const p of ph){sx+=Math.cos(p.phase);sy+=Math.sin(p.phase);}
      const N=ph.length; const R=Math.hypot(sx/N,sy/N); const meanPhase=Math.atan2(sy/N,sx/N);
      setOmegaAudio(R);
      // advance phases: natural freq + coupling pull toward mean field, scaled by beat
      for(let i=0;i<N;i++){
        const p=ph[i];
        p.phase+=(p.nat*beatHz*TAU*dt)+(K*R*Math.sin(meanPhase-p.phase)*dt*6);
        if(p.phase>TAU*1e6)p.phase=p.phase%TAU;
      }
      // SMOOTH AMBIENT envelopes (no percussion) - each voice swells gently on its
      // own phase so the field evolves slowly and musically instead of pulsing.
      const nodes=nodesRef.current; const audioNow=ctx2.currentTime;
      if(nodes){
        for(let i=0;i<nodes.length;i++){
          const nd=nodes[i],def=nd.def,p=ph[i];
          // continuous raised-cosine swell from phase; coherence (R) fills it in.
          const swell=0.5+0.5*Math.sin(p.phase);
          const breath=0.35+0.65*Math.pow(swell,1.5);   // soft, never zero -> no clicks
          const cohFill=0.55+0.45*R;                      // tighter lock -> fuller drone
          const target=nd.muted?0:breath*nd.level*cohFill*0.5;
          nd.g.gain.setTargetAtTime(clamp(target,0,0.85),audioNow,0.18); // long smoothing
          // gentle detune drift toward 0 plus user offset, slow
          nd.osc.detune.setTargetAtTime(nd.detune,audioNow,0.25);
        }
      }
      stepRef.current++;
      if(stepRef.current%6===0){
        // mirror to UI occasionally (not every frame)
        setLayers(nodesRef.current?nodesRef.current.map((nd,i)=>({id:nd.def.id,label:nd.def.label,color:nd.def.color,muted:nd.muted,level:nd.level,detune:nd.detune,phase:(ph[i].phase%TAU)/TAU})):[]);
      }
      rafRef.current=requestAnimationFrame(loop);
    };
    rafRef.current=requestAnimationFrame(loop);
  },[active,buildGraph,master,LAYER_DEFS]);

  const bpmRef=useRef(96); useEffect(()=>{bpmRef.current=bpm;},[bpm]);
  useEffect(()=>{couplingRef.current=coupling;},[coupling]);
  useEffect(()=>{dropRef.current=drop;},[drop]);
  useEffect(()=>{ const m=masterGainRef.current,ctx=_audioCtx; if(m&&ctx){ m.gain.setTargetAtTime(active?master:0,ctx.currentTime,0.08); } },[master,active]);

  const stop=useCallback(()=>{
    if(rafRef.current)cancelAnimationFrame(rafRef.current);
    const ctx=_audioCtx;
    if(masterGainRef.current&&ctx){ masterGainRef.current.gain.setTargetAtTime(0,ctx.currentTime,0.1); }
    setActive(false); setOmegaAudio(0);
  },[]);

  // DJ controls
  const toggleLayer=useCallback((id)=>{ const nodes=nodesRef.current; if(!nodes)return; const nd=nodes.find(n=>n.def.id===id); if(nd){nd.muted=!nd.muted;} setLayers(nodes.map((n,i)=>({id:n.def.id,label:n.def.label,color:n.def.color,muted:n.muted,level:n.level,detune:n.detune,phase:0}))); },[]);
  const nudgeDetune=useCallback((id,cents)=>{ const nodes=nodesRef.current; if(!nodes)return; const nd=nodes.find(n=>n.def.id===id); if(nd){nd.detune=clamp(nd.detune+cents,-1200,1200);} },[]);
  const setLayerLevel=useCallback((id,lvl)=>{ const nodes=nodesRef.current; if(!nodes)return; const nd=nodes.find(n=>n.def.id===id); if(nd){nd.level=clamp(lvl,0,1);} },[]);
  const scatter=useCallback(()=>{ const ph=phaseRef.current; if(ph){for(const p of ph)p.phase=Math.random()*TAU;} },[]);
  const align=useCallback(()=>{ const ph=phaseRef.current; if(ph){const a=Math.random()*TAU;for(const p of ph)p.phase=a;} },[]);
  const triggerDrop=useCallback(()=>{ setDrop(true); setTimeout(()=>setDrop(false),1800); },[]);
  const detuneAll=useCallback((cents)=>{ const nodes=nodesRef.current; if(!nodes)return; for(const nd of nodes)nd.detune=clamp(nd.detune+cents,-1200,1200); },[]);

  useEffect(()=>()=>{ if(rafRef.current)cancelAnimationFrame(rafRef.current); },[]);

  return { active,start,stop,layers,coupling,setCoupling,omegaAudio,master,setMaster,bpm,setBpm,drop,
           toggleLayer,nudgeDetune,setLayerLevel,scatter,align,triggerDrop,detuneAll,
           hasNodes:()=>!!nodesRef.current };
}

